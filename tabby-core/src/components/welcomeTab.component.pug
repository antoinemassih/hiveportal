.hive-welcome
    .hive-header
        h1.hive-title HivePortal
        .hive-subtitle Your development workspace
        .hive-actions
            button.btn.btn-outline-primary.btn-sm((click)='newProject()')
                i.fas.fa-plus.me-1
                span New Project
            button.btn.btn-outline-secondary.btn-sm.ms-2((click)='closeAndDisable()')
                span Don't show on startup

    .hive-new-project(*ngIf='showNewForm')
        .card
            .card-body
                h5.card-title New Project
                .form-group.mb-2
                    label.form-label Name
                    input.form-control.form-control-sm(
                        [(ngModel)]='newName',
                        placeholder='my-project'
                    )
                .form-group.mb-2
                    label.form-label Display Name
                    input.form-control.form-control-sm(
                        [(ngModel)]='newDisplayName',
                        placeholder='My Project'
                    )
                .form-group.mb-2
                    label.form-label Local Folder
                    .input-group.input-group-sm
                        input.form-control(
                            [(ngModel)]='newLocalPath',
                            placeholder='/Users/you/Documents/my-project'
                        )
                        button.btn.btn-outline-secondary(type='button', (click)='browseFolder()')
                            i.fas.fa-folder-open
                .form-group.mb-2
                    label.form-label GitHub (optional)
                    input.form-control.form-control-sm(
                        [(ngModel)]='newGithub',
                        placeholder='username/repo'
                    )
                .form-group.mb-2
                    label.form-label Description
                    input.form-control.form-control-sm(
                        [(ngModel)]='newDescription',
                        placeholder='What this project does'
                    )
                .form-group.mb-3
                    label.form-label Tags (comma separated)
                    input.form-control.form-control-sm(
                        [(ngModel)]='newTags',
                        placeholder='nextjs, python, api'
                    )
                .d-flex.gap-2
                    button.btn.btn-primary.btn-sm((click)='createProject()', [disabled]='!newName')
                        i.fas.fa-check.me-1
                        span Create
                    button.btn.btn-secondary.btn-sm((click)='showNewForm = false')
                        span Cancel

    .hive-search(*ngIf='!showNewForm')
        input.form-control(
            type='text',
            placeholder='Search projects...',
            [(ngModel)]='searchQuery',
            (ngModelChange)='filterProjects()'
        )

    .hive-projects(*ngIf='!showNewForm')
        .hive-project-card(
            *ngFor='let project of filteredProjects'
        )
            .card-header
                .project-name {{ project.display_name || project.name }}
                .project-tags
                    span.badge.bg-secondary.me-1(*ngFor='let tag of (project.tags || []).slice(0, 3)') {{ tag }}
            .card-desc(*ngIf='project.description') {{ project.description }}
            .card-meta
                span.meta-item(*ngIf='project.localDir')
                    i.fas.fa-folder.me-1
                    span {{ project.localDir }}
                span.meta-item(*ngIf='!project.localDir')
                    i.fas.fa-folder.me-1
                    span.text-muted no local folder
                span.meta-item(*ngIf='project.infra?.domain')
                    i.fas.fa-globe.me-1
                    span {{ project.infra.domain }}
            .card-actions
                button.btn.btn-sm.btn-primary((click)='openTerminal(project)')
                    i.fas.fa-terminal.me-1
                    span Terminal
                button.btn.btn-sm.btn-success.ms-2((click)='openClaude(project)')
                    i.fas.fa-robot.me-1
                    span Claude

    .hive-loading(*ngIf='loading')
        .spinner-border.spinner-border-sm.me-2
        span Loading projects...

    .hive-error(*ngIf='error')
        .alert.alert-warning {{ error }}
